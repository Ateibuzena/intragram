# ==============================
# Global Docker Compose settings
# File: /.env (root)
# ==============================

# Gateway auth
JWT_SECRET=change-this-super-secret-jwt-key

# Auth DB (used by auth-db and auth-service)
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password
AUTH_DB_NAME=auth_db

# CORS (use https://localhost:8443 if frontend goes through nginx)
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ------------------------------
# Suggested shared values (future-proof)
# These are not interpolated yet by docker-compose.yml,
# but kept here to centralize all service config.
# ------------------------------
NODE_ENV=development
GATEWAY_PORT=3000
EXAMPLE_SERVICE_PORT=3005
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
NGINX_HTTPS_PORT=8443

EXAMPLE_SERVICE_URL=http://example-service:3005
AUTH_SERVICE_URL=http://auth-service:3003
CHAT_SERVICE_URL=http://chat-service:3004
GRAFANA_URL=http://grafana:3001
