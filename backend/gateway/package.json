{
  "name": "gateway",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build":       "tsc",
    "start":       "node dist/main.js",
    "start:dev":   "ts-node -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start:watch": "ts-node-dev --poll --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/main.ts"
  },
  "dependencies": {
    "@intragram/shared":          "1.0.0",
    "@nestjs/axios":              "^4.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/websockets":         "^11.1.14",
    "nestjs-pino":   "^4.6.0",
    "pino":          "^10.3.1",
    "pino-http":     "^11.0.0",
    "pino-pretty":   "^13.1.3",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc":         "^3.2.0",
    "@eslint/js":               "^9.18.0",
    "@nestjs/cli":              "^11.0.0",
    "@nestjs/schematics":       "^11.0.0",
    "@nestjs/testing":          "^11.0.1",
    "@types/express":           "^5.0.0",
    "@types/jest":              "^30.0.0",
    "@types/supertest":         "^6.0.2",
    "eslint":                   "^9.18.0",
    "eslint-config-prettier":   "^10.0.1",
    "eslint-plugin-prettier":   "^5.2.2",
    "globals":                  "^16.0.0",
    "jest":                     "^30.0.0",
    "prettier":                 "^3.4.2",
    "source-map-support":       "^0.5.21",
    "supertest":                "^7.0.0",
    "ts-jest":                  "^29.2.5",
    "ts-loader":                "^9.5.2",
    "tsconfig-paths":           "^4.2.0",
    "typescript-eslint":        "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}