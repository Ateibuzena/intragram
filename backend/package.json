{
  "name": "intragram-backend",
  "private": true,
  "workspaces": [
    "gateway",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev:gateway": "npm run start:watch -w gateway",
    "dev:auth":    "npm run start:watch -w services/auth",
    "dev:users":   "npm run start:watch -w services/users",
    "dev:chat":    "npm run start:watch -w services/chat",
    "build:gateway": "npm run build -w gateway",
    "build:auth":    "npm run build -w services/auth",
    "build:users":   "npm run build -w services/users",
    "build:chat":    "npm run build -w services/chat"
  },
  "dependencies": {
    "@nestjs/common":           "^11.1.14",
    "@nestjs/core":             "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "class-transformer":  "^0.5.1",
    "class-validator":    "^0.15.1",
    "dotenv":             "^17.3.1",
    "jsonwebtoken":       "^9.0.3",
    "prom-client":        "^15.1.3",
    "reflect-metadata":   "^0.2.2",
    "rxjs":               "^7.8.1"
  },
  "devDependencies": {
    "ts-node":        "^10.9.2",
    "ts-node-dev":    "^2.0.0",
    "typescript":     "^5.7.3",
    "@types/node":    "^22.10.7",
    "nodemon":        "^3.0.2"
  }
}