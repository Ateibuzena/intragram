{
  "name": "chat-service",
  "version": "1.0.0",
  "description": "Microservicio de chat con WebSocket",
  "main": "dist/main.js",
  "scripts": {
    "build":       "tsc",
    "start":       "node dist/main.js",
    "start:dev":   "ts-node -r dotenv/config src/main.ts",
    "start:watch": "ts-node-dev --poll --respawn --transpile-only src/main.ts"
  },
  "dependencies": {
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/websockets":         "^11.1.14",
    "cookie-parser":              "^1.4.6",
    "socket.io":                  "^4.8.1"
  },
  "devDependencies": {}
}