{
	"name": "chat-service",
	"version": "1.0.0",
	"description": "Microservicio de chat con WebSocket y persistencia en memoria",
	"main": "dist/main.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/main.js",
		"start:dev": "ts-node -r dotenv/config src/main.ts",
		"start:watch": "ts-node-dev --poll --respawn --transpile-only src/main.ts"
	},
	"dependencies": {
		"cookie-parser": "^1.4.6",
		"jsonwebtoken": "^9.0.0",
		"@nestjs/common": "^11.0.1",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/platform-socket.io": "^11.1.14",
		"@nestjs/websockets": "^11.1.14",
		"@willsoto/nestjs-prometheus": "^6.0.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"dotenv": "^16.4.5",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"socket.io": "^4.8.1"
	},
	"devDependencies": {
    "ts-node-dev": "^2.0.0",
		"@types/node": "^22.10.7",
		"nodemon": "^3.0.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	}
}
