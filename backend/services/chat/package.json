{
  "name": "chat-service",
  "version": "1.0.0",
  "description": "Microservicio de chat con WebSocket",
  "main": "dist/main.js",
  "scripts": {
    "build":       "tsc",
    "start":       "node dist/main.js",
    "start:dev":   "ts-node -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start:watch": "ts-node-dev --poll --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/main.ts"
  },
  "dependencies": {
    "@intragram/shared":        "1.0.0",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/websockets":         "^11.1.14",
    "@nestjs/typeorm":           "^11.0.0",
    "cookie-parser":            "^1.4.6",
    "pg":                       "^8.13.1",
    "socket.io":                "^4.8.1",
    "typeorm":                  "^0.3.20"
  },
  "devDependencies": {
    "tsconfig-paths":       "^4.2.0"
  }
}